{
  "name": "f1-insightx",
  "private": true,
  "version": "0.1.0",
  "description": "Portfolio-grade Formula 1 race strategy and fantasy analytics platform.",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace web",
    "build": "npm run build --workspace web",
    "lint": "npm run lint --workspace web",
    "test": "npm run test --workspace web",
    "audit": "npm audit",
    "audit:prod": "npm audit --omit=dev",
    "typecheck": "npx tsc --noEmit --project apps/web/tsconfig.json",
    "data:install": "python -m pip install -r data/requirements.txt",
    "data:manifest": "python build_product_manifest.py",
    "data:validate": "python validate_product_manifest.py",
    "data:guard": "python check_generated_artifacts.py"
  },
  "overrides": {
    "eslint": {
      "brace-expansion": "1.1.13"
    },
    "@typescript-eslint/typescript-estree": {
      "brace-expansion": "5.0.5"
    },
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "tinyglobby": {
      "picomatch": "4.0.4"
    },
    "fdir": {
      "picomatch": "4.0.4"
    }
  },
  "keywords": [
    "formula-1",
    "nextjs",
    "supabase",
    "analytics",
    "fantasy-sports"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "ws": "^8.21.0"
  }
}
