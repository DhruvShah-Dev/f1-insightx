# App
# In this monorepo, place .env.local at the repo root or apps/web/.env.local.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set this before public launch so privacy and deletion requests have a visible contact path.
NEXT_PUBLIC_PRIVACY_CONTACT_EMAIL=

# Public browser auth settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local data loading only. Do not expose in browser code.
DATABASE_URL=

# Server-only. Never expose this key to browser code or public client bundles.
SUPABASE_SERVICE_ROLE_KEY=

# Abuse protection / rate limits:
# Optional for production-grade shared rate limiting. Without these, the app falls back to
# an in-memory limiter that is acceptable for local development only.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Tune route limits in apps/web/src/lib/security/rate-limit.ts if needed.

# Data sources
# The Python data pipeline uses Jolpica and FastF1 for ingestion. Runtime app pages do not require
# extra browser-exposed data-source secrets by default.
JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1

# CI and scheduled refresh
GITHUB_ACTIONS=false
